# =========================================================================
#  .gitignore — MATLAB / Simulink thesis project
#  Keeps source scripts, the Simulink model, the dataset, the trained model,
#  the waveform captures, the figures, and the result summaries.
#  Ignores temporary files, caches, autosaves, and model backups.
# =========================================================================

# --- MATLAB temporary / autosave files ---
*.asv
*.m~
*.autosave

# --- MATLAB / MEX build artefacts ---
*.mex*
*.o
*.obj
slprj/
codegen/

# --- Simulink cache / autosave / recovery ---
*.slxc
*.slx.autosave
*.slx.r*
*.slx.original
*_backup_*.slx

# --- Rolling checkpoints (regenerable) ---
dataset_checkpoint_v2.mat

# The committed .mat archive lives under outputs/ (dataset, model, waveforms)
# and under src/ (the .slx model); these are intentionally tracked.

# --- OS / editor noise ---
.DS_Store
Thumbs.db
desktop.ini
*.tmp
*.bak
.vscode/
